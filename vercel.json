{
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "create-react-app"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "server:app",
      "installCommand": "pip install fastapi==0.110.1 motor==3.3.1 pymongo==4.6.3 \"cryptography>=42.0.8\" \"python-dotenv>=1.0.1\" \"pydantic>=2.6.4\""
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
